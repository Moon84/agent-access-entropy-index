{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Access Entropy Index Access Resource",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resource_id",
    "platform_en",
    "platform_zh",
    "product_or_resource",
    "domain_en",
    "domain_zh",
    "country_region",
    "access_resource_types",
    "official_cli",
    "official_skill",
    "official_mcp",
    "official_sdk_api",
    "source_url",
    "official_status_en",
    "official_status_zh",
    "verification_status",
    "openness_level",
    "risk_level",
    "description_en",
    "description_zh",
    "source_dataset",
    "checked_at"
  ],
  "properties": {
    "resource_id": {
      "type": "string",
      "description": "Stable row identifier.",
      "examples": [
        "aar-0001"
      ]
    },
    "platform_en": {
      "type": "string",
      "description": "English or romanized platform/vendor name.",
      "examples": [
        "X"
      ]
    },
    "platform_zh": {
      "type": "string",
      "description": "Chinese platform/vendor name when available.",
      "examples": [
        "X / Twitter"
      ]
    },
    "product_or_resource": {
      "type": "string",
      "description": "Product, platform, repository, or resource name.",
      "examples": [
        "X / Twitter"
      ]
    },
    "domain_en": {
      "type": "string",
      "description": "English domain/category.",
      "examples": [
        "Social media"
      ]
    },
    "domain_zh": {
      "type": "string",
      "description": "Chinese domain/category.",
      "examples": [
        "社交媒体"
      ]
    },
    "country_region": {
      "type": "string",
      "description": "Country or region when known.",
      "examples": [
        ""
      ]
    },
    "access_resource_types": {
      "type": "string",
      "description": "Semicolon-delimited resource types such as CLI, Skill, MCP, SDK/API, Plugin.",
      "examples": [
        "CLI"
      ]
    },
    "official_cli": {
      "type": "string",
      "description": "Official CLI availability/status.",
      "examples": [
        "有"
      ]
    },
    "official_skill": {
      "type": "string",
      "description": "Official Agent Skill availability/status.",
      "examples": [
        "未确认"
      ]
    },
    "official_mcp": {
      "type": "string",
      "description": "Official MCP availability/status.",
      "examples": [
        "未确认"
      ]
    },
    "official_sdk_api": {
      "type": "string",
      "description": "Official SDK/API availability/status.",
      "examples": [
        ""
      ]
    },
    "source_url": {
      "type": "string",
      "description": "Primary official or evidence URL.",
      "examples": [
        "https://github.com/xdevplatform/xurl"
      ]
    },
    "official_status_en": {
      "type": "string",
      "description": "English official-source status.",
      "examples": [
        "Confirmed CLI"
      ]
    },
    "official_status_zh": {
      "type": "string",
      "description": "Chinese official-source status.",
      "examples": [
        "已确认 CLI"
      ]
    },
    "verification_status": {
      "type": "string",
      "description": "Original verification/status value.",
      "examples": [
        "已确认 CLI"
      ]
    },
    "openness_level": {
      "type": "string",
      "description": "Interface/data openness level where available.",
      "examples": [
        ""
      ]
    },
    "risk_level": {
      "type": "string",
      "description": "Rough risk label inferred from capability and category.",
      "examples": [
        "Medium"
      ]
    },
    "description_en": {
      "type": "string",
      "description": "English description when available.",
      "examples": [
        ""
      ]
    },
    "description_zh": {
      "type": "string",
      "description": "Chinese description when available.",
      "examples": [
        "官方 X API CLI 生态明确；Skill/MCP 未确认官方"
      ]
    },
    "source_dataset": {
      "type": "string",
      "description": "Source CSV used to build the row.",
      "examples": [
        "02-platforms.csv"
      ]
    },
    "checked_at": {
      "type": "string",
      "description": "Last checked date.",
      "examples": [
        "2026-07-06"
      ]
    }
  }
}
